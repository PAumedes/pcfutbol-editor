{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pcf-editor",
  "version": "0.0.1",
  "identifier": "com.pcfutbol.editor",
  "build": {
    "frontendDist": "../ui/dist",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PC Apertura 98/99 Editor",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
