/target
/ui/node_modules
/ui/dist
/src-tauri/target
/src-tauri/gen

# Local cross-compiled Windows binary, copied out of the dev container for
# manual smoke-testing on the host — not a build artifact anyone else needs.
/windows-build
*.bak
.DS_Store

# Regenerated by pcf-manager's tests on every `cargo test` run — not an
# authored fixture, no need to track the binary blob.
/fixtures/manager_synthetic/*.bin

# Real, user-supplied/extracted game data — never commit proprietary
# Dinamic assets (PLAN.md §1 "own-copy only"). See fixtures/README.md.
# Any file under fixtures/golden/ is excluded by default (this covers raw
# extracted container blobs like real_river_9001_container_blob.raw, not
# just *.dbc) except READMEs and explicitly SYNTHETIC placeholders
# (filenames containing "synthetic"), which stay tracked for TDD.
fixtures/golden/*
!fixtures/golden/*.md
!fixtures/golden/*synthetic*
fixtures/manager/*.exe
fixtures/manager/*.bak
!fixtures/manager/*synthetic*
.commit-msg.txt

# Claude Code harness internals, not project content.
/.claude/
