.DS_Store

# Regenerated by pcf-manager's tests on every `cargo test` run — not an
# authored fixture, no need to track the binary blob.
/fixtures/manager_synthetic/*.bin

# Real, user-supplied game data — never commit proprietary Dinamic assets
# (PLAN.md §1 "own-copy only"). See fixtures/README.md. Agents' explicitly
# SYNTHETIC placeholder fixtures (filenames containing "synthetic") are
# intentionally exempted below so they stay tracked for TDD.
fixtures/golden/*.dbc
fixtures/golden/*.DBC
!fixtures/golden/*synthetic*
fixtures/manager/*.exe
fixtures/manager/*.bak
!fixtures/manager/*synthetic*
